# ============================================================================
# Tickra — environment variables
#
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# On Vercel, set the same variables in Project Settings → Environment Variables.
# ============================================================================

# Public site URL — used for OAuth redirects, OG images, Stripe callbacks
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Supabase ----------
# Create a project at https://supabase.com/dashboard
# Settings → API → Project URL + anon public key + service_role key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Stripe ----------
# Create products at https://dashboard.stripe.com/test/products
# Three price IDs are required:
#   - Pro monthly recurring
#   - Pro yearly recurring (optional, can match monthly id for now)
#   - Lifetime one-time
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_LIFETIME=

# ---------- Email (Resend) ----------
# Create an API key at https://resend.com/api-keys
# EMAIL_FROM must be a verified sender on a domain you own.
RESEND_API_KEY=
EMAIL_FROM=Tickra <hello@tickra.com>
EMAIL_REPLY_TO=hello@tickra.com
