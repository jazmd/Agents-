# RuFlo Research — Environment Configuration
#
# Two classes of environment variables:
#
#   1. CLIENT-side (browser bundle) — MUST be prefixed with `VITE_`.
#      Vite inlines these into the JS bundle. Treat as PUBLIC.
#
#   2. SERVER-side (Node functions / GCF environment) — MUST NOT be
#      prefixed with `VITE_`. These never reach the browser.
#
# Per ADR-093 §S1 (security): API keys (ANTHROPIC_API_KEY etc.)
# NEVER use the VITE_ prefix. The Lovable AI Gateway dependency was
# removed at branch HEAD; functions now call Anthropic Messages API
# directly with credentials from gcloud Secret Manager (or local env).

# ─── Client-side (Vite-exposed) ─────────────────────────────────────

# Feature flag — gates the IndexedDB-backed RVF persistence layer
# (widgetConfig, userGoal, researchConfig). Set to `true` in dev to
# preserve state across reloads.
VITE_RVF_ENABLED=false

# Base URL for server-side functions (the LOCAL_FN / GCF replacements
# for the former Supabase Edge Functions).
#   Dev:  http://localhost:8787   (Hono server, see `npm run functions:dev`)
#   Prod: https://<region>-<project>.cloudfunctions.net  (or your CDN front)
VITE_FUNCTIONS_BASE_URL=http://localhost:8787

# Weak abuse-control token sent as `X-RuFlo-Token` header. Server
# validates against `RUFLO_FUNCTIONS_TOKEN` (server-side, NOT prefixed
# with VITE_). This token is embedded in the bundle by design — it
# defends against random scanning callers, NOT motivated attackers;
# rate-limit + CORS allowlist are the real controls (Step 22b).
VITE_FUNCTIONS_PUBLIC_TOKEN=dev-token-change-me

# ─── Server-side (function environment, NEVER VITE_-prefixed) ──────
#
# These are listed here for documentation only — set them in the
# function host's environment (e.g. `gcloud functions deploy --set-env-vars`,
# Hono's local `.env.local`, or a process manager). They MUST NOT be
# committed to git, and MUST NEVER appear with a VITE_ prefix.
#
# ── LLM credentials (resolved by functions/_lib/secrets.ts) ────────
# Resolution order:
#   1. ANTHROPIC_API_KEY env var (fastest local-dev path)
#   2. Google Cloud Secret Manager (prod / shared-dev)
#      - GCLOUD_PROJECT_ID (or GOOGLE_CLOUD_PROJECT auto-set by GCF)
#      - RUFLO_ANTHROPIC_SECRET_NAME (default: ruflo-anthropic-api-key)
#   3. Fall through → mock mode (canned [mock] responses)
#
# ANTHROPIC_API_KEY=sk-ant-...                # local dev only
# GCLOUD_PROJECT_ID=my-gcp-project            # required for Secret Manager fallback
# RUFLO_ANTHROPIC_SECRET_NAME=ruflo-anthropic-api-key  # override default secret name
# RUFLO_LLM_MODEL=claude-haiku-4-5-20251001   # override default model
#
# ── Functions plumbing ─────────────────────────────────────────────
# RUFLO_FUNCTIONS_TOKEN=...     # paired with VITE_FUNCTIONS_PUBLIC_TOKEN
# RUFLO_ALLOWED_ORIGINS=...     # CORS allowlist override (default: localhost:8080,goal.ruv.io)
# RUFLO_RATE_LIMIT_PER_MIN=60   # per-IP token-bucket cap
